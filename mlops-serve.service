[Unit]
Description=MLOps FastAPI Service
After=network.target

[Service]
User=github
WorkingDirectory=/home/github/mlops-lab
Environment="GOOGLE_APPLICATION_CREDENTIALS=/home/github/mlops-lab/sa-key.json"
Environment="GCS_BUCKET=mlops-lab-bucket-calm-streamer-499804-e6"
ExecStart=/home/github/mlops-lab/venv/bin/uvicorn src.serve:app --host 0.0.0.0 --port 8000
Restart=always

[Install]
WantedBy=multi-user.target
